/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 220rpx;
  background: linear-gradient(180deg, #FFF8F0 0%, #FFF 100%);
}

/* 步骤指示器 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 10rpx;
}

.step-dots {
  display: flex;
  align-items: center;
}

.dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #E0E0E0;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot.active {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
}

.dot.done {
  background: #4CAF50;
}

.line {
  width: 80rpx;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 8rpx;
}

.line.active {
  background: linear-gradient(90deg, #8B1A1A, #C0392B);
}

.step-text {
  font-size: 28rpx;
  color: #8B1A1A;
  font-weight: bold;
  margin-top: 12rpx;
}

/* 结果展示 */
.result-showcase {
  padding: 20rpx 30rpx;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(139,26,26,0.2);
  position: relative;
}

.result-image {
  width: 100%;
  height: 600rpx;
  display: block;
}

.style-badge {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  background: rgba(139,26,26,0.9);
  color: #fff;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  backdrop-filter: blur(10rpx);
}

.badge-text {
  font-size: 28rpx;
  font-weight: bold;
}

.badge-mode {
  font-size: 24rpx;
  margin-left: 8rpx;
  opacity: 0.9;
}

/* 操作按钮 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 30rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 30rpx 10rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.action-text {
  font-size: 24rpx;
  color: #666;
}

/* 推荐 */
.suggestions {
  margin: 0 30rpx 20rpx;
}

.suggestions-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.suggestions-scroll {
  white-space: nowrap;
}

.suggestion-item {
  display: inline-block;
  margin-right: 20rpx;
  text-align: center;
}

.suggestion-img {
  width: 140rpx;
  height: 180rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.suggestion-name {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.bottom-nav button {
  flex: 1;
}

/* 分享弹窗 */
.share-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-content {
  background: #fff;
  width: 100%;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.share-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.share-platforms {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.share-icon {
  width: 100rpx;
  height: 100rpx;
  background: #f5f5f5;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.share-btn text {
  font-size: 24rpx;
  color: #666;
}

.share-cancel {
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
