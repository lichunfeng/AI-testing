/* pages/upload/upload.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 步骤指示器 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.step-dots {
  display: flex;
  align-items: center;
}

.dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #E0E0E0;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot.active {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
}

.line {
  width: 60rpx;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 8rpx;
}

.step-text {
  font-size: 32rpx;
  color: #8B1A1A;
  font-weight: bold;
  margin-top: 16rpx;
}

/* 上传区域 */
.upload-area {
  margin: 30rpx;
}

.upload-box {
  background: #fff;
  border: 4rpx dashed #D0D0D0;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.upload-box.has-image {
  border-style: solid;
  border-color: #8B1A1A;
  padding: 20rpx;
}

.upload-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.upload-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.upload-desc {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
}

.change-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 16rpx 40rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
}

/* 模式提示 */
.mode-tips {
  margin: 20rpx 30rpx;
}

.tip-row {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.tip-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 注意事项 */
.notice {
  margin: 20rpx 30rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666;
  line-height: 44rpx;
}

/* 操作区域 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,248,240,0.95);
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  text-align: center;
}

.action-area button {
  width: 100%;
}

/* 加载动画 */
.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
