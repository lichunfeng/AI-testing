/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 横幅 */
.banner {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.banner-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  filter: brightness(0.6);
}

.banner-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  color: #fff;
}

.banner-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
  letter-spacing: 4rpx;
}

.banner-subtitle {
  display: block;
  font-size: 28rpx;
  margin-top: 16rpx;
  opacity: 0.9;
}

/* 模式选择 */
.entry-section {
  margin: 30rpx;
}

.mode-cards {
  display: flex;
  justify-content: space-between;
}

.mode-card {
  flex: 1;
  margin: 0 10rpx;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.mode-card.active {
  background: linear-gradient(135deg, #8B1A1A, #A02020);
  box-shadow: 0 8rpx 24rpx rgba(139,26,26,0.4);
}

.mode-card.active text {
  color: #fff !important;
}

.mode-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.mode-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.mode-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.mode-check {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  color: #8B1A1A;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

/* 民族服饰 */
.nation-section {
  margin: 30rpx;
}

.nation-scroll {
  white-space: nowrap;
  margin: 0 -30rpx;
  padding: 0 30rpx;
}

.nation-item {
  display: inline-block;
  margin-right: 24rpx;
  text-align: center;
}

.nation-img {
  width: 160rpx;
  height: 200rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.nation-name {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
}

/* 主题风格 */
.theme-section {
  margin: 30rpx;
}

.theme-cards {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.theme-card {
  width: 48%;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.theme-img {
  width: 100%;
  height: 200rpx;
}

.theme-info {
  padding: 20rpx;
}

.theme-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.theme-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 操作区域 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,248,240,0.95);
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  text-align: center;
}

.start-btn {
  width: 80%;
  height: 96rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.btn-icon {
  margin-right: 12rpx;
}

.tips {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
