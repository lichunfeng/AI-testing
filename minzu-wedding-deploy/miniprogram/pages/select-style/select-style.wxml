<!-- pages/select-style/select-style.wxml -->
<view class="container">
  <!-- 顶部步骤 -->
  <view class="header">
    <view class="step-dots">
      <view class="dot done">✓</view>
      <view class="line active"></view>
      <view class="dot active">2</view>
      <view class="line"></view>
      <view class="dot">3</view>
    </view>
    <text class="step-text">选择服饰风格</text>
  </view>

  <!-- 照片预览 -->
  <view class="photo-preview">
    <image class="photo" src="{{uploadedImage}}" mode="aspectFit"></image>
    <view class="photo-tag">{{mode === 'couple' ? '合照模式' : '单人模式'}}</view>
  </view>

  <!-- 风格分类Tab -->
  <view class="style-tabs">
    <view 
      class="tab {{currentTab === 'nations' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="nations">
      民族服饰
    </view>
    <view 
      class="tab {{currentTab === 'themes' ? 'active' : ''}}" 
      bindtap="switchTab" 
      data-tab="themes">
      婚礼主题
    </view>
  </view>

  <!-- 民族服饰列表 -->
  <scroll-view 
    class="style-list" 
    scroll-y 
    wx:if="{{currentTab === 'nations'}}"
    bindscrolltolower="loadMoreNations">
    
    <!-- 热门民族 -->
    <view class="category-section" wx:if="{{nations.length > 0}}">
      <view class="section-title">🔥 热门民族</view>
      <view class="style-grid">
        <view 
          class="style-card {{selectedNation && selectedNation.id === item.id ? 'selected' : ''}}"
          wx:for="{{displayNations}}"
          wx:key="id"
          bindtap="selectNation"
          data-nation="{{item}}">
          <view class="style-img-wrap">
            <image class="style-img" src="{{item.image}}" mode="aspectFill"></image>
            <view class="style-tag" wx:if="{{item.isHot}}">热</view>
          </view>
          <view class="style-info">
            <text class="style-name">{{item.name}}</text>
            <text class="style-desc">{{item.desc}}</text>
          </view>
          <view class="select-check" wx:if="{{selectedNation && selectedNation.id === item.id}}">✓</view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{loadingMore}}">
      <text>加载中...</text>
    </view>
  </scroll-view>

  <!-- 婚礼主题列表 -->
  <scroll-view 
    class="style-list" 
    scroll-y 
    wx:if="{{currentTab === 'themes'}}">
    
    <view class="theme-full-list">
      <view 
        class="theme-full-card {{selectedTheme && selectedTheme.id === item.id ? 'selected' : ''}}"
        wx:for="{{themes}}"
        wx:key="id"
        bindtap="selectTheme"
        data-theme="{{item}}">
        <image class="theme-full-img" src="{{item.image}}" mode="aspectFill"></image>
        <view class="theme-full-info">
          <text class="theme-full-name">{{item.name}}</text>
          <text class="theme-full-desc">{{item.desc}}</text>
          <view class="theme-colors">
            <view 
              class="color-dot" 
              wx:for="{{item.colors}}" 
              wx:for-item="color"
              style="background:{{color}}"></view>
          </view>
        </view>
        <view class="select-check" wx:if="{{selectedTheme && selectedTheme.id === item.id}}">✓</view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作 -->
  <view class="action-area">
    <view class="selected-info" wx:if="{{selectedNation || selectedTheme}}">
      <text wx:if="{{selectedNation}}">已选：{{selectedNation.name}}婚礼服饰</text>
      <text wx:if="{{selectedTheme}}">已选：{{selectedTheme.name}}</text>
    </view>
    <button 
      class="btn-primary {{!hasSelection ? 'disabled' : ''}}" 
      bindtap="startDress"
      disabled="{{!hasSelection}}">
      <text wx:if="{{!processing}}">🎨 开始换装</text>
      <text wx:if="{{processing}}">AI换装中...</text>
    </button>
  </view>
</view>

<!-- 加载遮罩 -->
<view class="loading-mask" wx:if="{{processing}}">
  <view class="processing-content">
    <view class="loading-spinner"></view>
    <text class="processing-title">AI正在为你换装</text>
    <text class="processing-step">{{processingStep}}</text>
  </view>
</view>
