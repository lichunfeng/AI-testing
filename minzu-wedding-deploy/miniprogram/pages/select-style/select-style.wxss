/* pages/select-style/select-style.wxss */
.container {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 步骤指示器 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  background: #fff;
}

.step-dots {
  display: flex;
  align-items: center;
}

.dot {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #E0E0E0;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot.active {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
}

.dot.done {
  background: #4CAF50;
}

.line {
  width: 80rpx;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 8rpx;
}

.line.active {
  background: linear-gradient(90deg, #8B1A1A, #C0392B);
}

.step-text {
  font-size: 28rpx;
  color: #8B1A1A;
  font-weight: bold;
  margin-top: 12rpx;
}

/* 照片预览 */
.photo-preview {
  position: relative;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.photo {
  width: 100%;
  height: 280rpx;
}

.photo-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(139,26,26,0.9);
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

/* Tab切换 */
.style-tabs {
  display: flex;
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 50rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #999;
  border-radius: 50rpx;
  transition: all 0.3s ease;
}

.tab.active {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  color: #fff;
  font-weight: bold;
}

/* 服饰列表 */
.style-list {
  height: calc(100vh - 550rpx);
  padding: 20rpx;
}

.category-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.style-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.style-card {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  position: relative;
}

.style-card.selected {
  box-shadow: 0 0 0 4rpx #8B1A1A;
  transform: scale(0.98);
}

.style-img-wrap {
  position: relative;
}

.style-img {
  width: 100%;
  height: 180rpx;
}

.style-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: #FF5722;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 12rpx 0;
}

.style-info {
  padding: 16rpx;
}

.style-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.style-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.select-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  background: #8B1A1A;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 主题卡片（全宽） */
.theme-full-list {
  padding: 10rpx 0;
}

.theme-full-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  position: relative;
  transition: all 0.3s ease;
}

.theme-full-card.selected {
  box-shadow: 0 0 0 4rpx #8B1A1A;
}

.theme-full-img {
  width: 200rpx;
  height: 160rpx;
}

.theme-full-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.theme-full-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.theme-full-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.theme-colors {
  display: flex;
  margin-top: 12rpx;
}

.color-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  border: 2rpx solid rgba(0,0,0,0.1);
}

/* 底部操作 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,248,240,0.95);
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.selected-info {
  text-align: center;
  font-size: 26rpx;
  color: #8B1A1A;
  margin-bottom: 12rpx;
}

.action-area button {
  width: 100%;
}

.action-area button.disabled {
  background: #ccc;
  box-shadow: none;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.processing-content {
  text-align: center;
  color: #fff;
}

.loading-spinner {
  width: 100rpx;
  height: 100rpx;
  border: 6rpx solid rgba(255,255,255,0.2);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.processing-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.processing-step {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}
