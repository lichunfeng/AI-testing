/* app.wxss - 全局样式 */
page {
  background-color: #FFF8F0;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: #333;
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #8B1A1A, #C0392B);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(139,26,26,0.35);
  letter-spacing: 2rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-secondary {
  background: #fff;
  color: #8B1A1A;
  border: 2rpx solid #8B1A1A;
  border-radius: 50rpx;
  padding: 22rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin: 20rpx 30rpx;
}

/* 标题 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B1A1A;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 8rpx;
  height: 36rpx;
  background: #8B1A1A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-text {
  color: #fff;
  font-size: 30rpx;
  margin-top: 24rpx;
}

/* 金色装饰线 */
.gold-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #D4AF37, transparent);
  margin: 20rpx 0;
}
